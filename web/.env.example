# Relative path — Vite proxies it to Fuseki (see vite.config.ts).
# To bypass the proxy and hit Fuseki directly, set a full URL like
# http://your-server:3030/culturalworks/sparql (Fuseki must allow CORS).
VITE_SPARQL_ENDPOINT=/sparql
VITE_ROOTS="http://localhost:3030/culturalworks/ontology#CreativeWork,http://localhost:3030/culturalworks/ontology#RealPerson,http://localhost:3030/culturalworks/ontology#Contribution,http://localhost:3030/culturalworks/ontology#FictionalCharacter,http://localhost:3030/culturalworks/ontology#AlternativeTitle"
VITE_APP_TITLE=Cultural Works Browser
