# Relative path — Vite proxies it to Fuseki (see vite.config.ts).
# To bypass the proxy and hit Fuseki directly, set a full URL like
# http://your-server:3030/culturalworks/sparql (Fuseki must allow CORS).
VITE_SPARQL_ENDPOINT=/sparql
VITE_ROOTS="https://example.org/culturalworks/ontology#CreativeWork,https://example.org/culturalworks/ontology#RealPerson,https://example.org/culturalworks/ontology#Contribution,https://example.org/culturalworks/ontology#FictionalCharacter,https://example.org/culturalworks/ontology#AlternativeTitle"
VITE_APP_TITLE=Cultural Works Browser
