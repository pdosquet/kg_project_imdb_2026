@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix cw: <https://example.org/culturalworks/ontology#>.
@prefix book: <https://example.org/culturalworks/book#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:rules_000 a void:Dataset;
    void:exampleResource :map_OlWork_000.
:map_OlWork_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/generated/ol_work.csv";
    rml:referenceFormulation ql:CSV.
:map_OlWork_000 a rr:TriplesMap;
    rdfs:label "OlWork".
:s_000 a rr:SubjectMap.
:map_OlWork_000 rr:subjectMap :s_000.
:s_000 rr:template "https://example.org/culturalworks/ol/work/{ol_work_key}".
:pom_000 a rr:PredicateObjectMap.
:map_OlWork_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:constant cw:CreativeWork;
    rr:termType rr:IRI.
:pom_001 a rr:PredicateObjectMap.
:map_OlWork_000 rr:predicateObjectMap :pom_001.
:pm_001 a rr:PredicateMap.
:pom_001 rr:predicateMap :pm_001.
:pm_001 rr:constant cw:primaryTitle.
:pom_001 rr:objectMap :om_001.
:om_001 a rr:ObjectMap;
    rml:reference "title";
    rr:termType rr:Literal.
:pom_002 a rr:PredicateObjectMap.
:map_OlWork_000 rr:predicateObjectMap :pom_002.
:pm_002 a rr:PredicateMap.
:pom_002 rr:predicateMap :pm_002.
:pm_002 rr:constant cw:startYear.
:pom_002 rr:objectMap :om_002.
:om_002 a rr:ObjectMap;
    rml:reference "first_publish_year";
    rr:termType rr:Literal;
    rr:datatype xsd:gYear.
:pom_003 a rr:PredicateObjectMap.
:map_OlWork_000 rr:predicateObjectMap :pom_003.
:pm_003 a rr:PredicateMap.
:pom_003 rr:predicateMap :pm_003.
:pm_003 rr:constant cw:hasType.
:pom_003 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rml:reference "work_type_iri";
    rr:termType rr:IRI.
:rules_000 void:exampleResource :map_OlWorkLanguage_000.
