:rules_000 void:exampleResource :map_AlternativeTitleMapping_000.
:map_AlternativeTitleMapping_000 rml:logicalSource :source_005.
:source_005 a rml:LogicalSource;
    rml:source "data/title_aka.csv";
    rml:referenceFormulation ql:CSV.
:map_AlternativeTitleMapping_000 a rr:TriplesMap;
    rdfs:label "AlternativeTitleMapping".
:s_005 a rr:SubjectMap.
:map_AlternativeTitleMapping_000 rr:subjectMap :s_005.
:s_005 a fnml:FunctionTermMap;
    rr:termType rr:IRI;
    fnml:functionValue :fn_000.
:fn_000 rml:logicalSource :source_005;
    rr:predicateObjectMap :pomexec_000.
:pomexec_000 rr:predicateMap :pmexec_000.
:pmexec_000 rr:constant fno:executes.
:pomexec_000 rr:objectMap :omexec_000.
:omexec_000 rr:constant "https://w3id.org/imec/idlab/function#trueCondition";
    rr:termType rr:IRI.
:fn_000 rr:predicateObjectMap :pom_002.
:pom_002 a rr:PredicateObjectMap;
    rr:predicateMap :pm_002.
:pm_002 a rr:PredicateMap;
    rr:constant <https://w3id.org/imec/idlab/function#strBoolean>.
:pom_002 rr:objectMap :om_002.
:om_002 a rr:ObjectMap, fnml:FunctionTermMap;
    fnml:functionValue :fn_001.
:fn_001 rml:logicalSource :source_005;
    rr:predicateObjectMap :pomexec_001.
:pomexec_001 rr:predicateMap :pmexec_001.
:pmexec_001 rr:constant fno:executes.
:pomexec_001 rr:objectMap :omexec_001.
:omexec_001 rr:constant "https://w3id.org/imec/idlab/function#equal";
    rr:termType rr:IRI.
:fn_001 rr:predicateObjectMap :pom_003.
:pom_003 a rr:PredicateObjectMap;
    rr:predicateMap :pm_003.
:pm_003 a rr:PredicateMap;
    rr:constant <http://users.ugent.be/~bjdmeest/function/grel.ttl#valueParameter>.
:pom_003 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rml:reference "is_original_title";
    rr:termType rr:Literal.
:fn_001 rr:predicateObjectMap :pom_004.
:pom_004 a rr:PredicateObjectMap;
    rr:predicateMap :pm_004.
:pm_004 a rr:PredicateMap;
    rr:constant <http://users.ugent.be/~bjdmeest/function/grel.ttl#valueParameter2>.
:pom_004 rr:objectMap :om_004.
:om_004 a rr:ObjectMap;
    rr:constant "0";
    rr:termType rr:Literal.
:fn_000 rr:predicateObjectMap :pom_005.
:pom_005 a rr:PredicateObjectMap;
    rr:predicateMap :pm_005.
:pm_005 a rr:PredicateMap;
    rr:constant <https://w3id.org/imec/idlab/function#str>.
:pom_005 rr:objectMap :om_005.
:om_005 a rr:ObjectMap;
    rr:template "http://localhost:3030/culturalworks/aka/{title_id}/{order}";
    rr:termType rr:IRI.
:pom_006 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_006.
:pm_006 a rr:PredicateMap.
:pom_006 rr:predicateMap :pm_006.
:pm_006 rr:constant rdf:type.
:pom_006 rr:objectMap :om_006.
:om_006 a rr:ObjectMap;
    rr:constant cw:AlternativeTitle;
    rr:termType rr:IRI.
:pom_007 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_007.
:pm_007 a rr:PredicateMap.
:pom_007 rr:predicateMap :pm_007.
:pm_007 rr:constant cw:akaTitle.
:pom_007 rr:objectMap :om_007.
:om_007 a rr:ObjectMap;
    rml:reference "aka_title";
    rr:termType rr:Literal.
:pom_008 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_008.
:pm_008 a rr:PredicateMap.
:pom_008 rr:predicateMap :pm_008.
:pm_008 rr:constant cw:isAltTitleOf.
:pom_008 rr:objectMap :om_008.
:om_008 a rr:ObjectMap;
    rr:template "http://localhost:3030/culturalworks/title/{title_id}";
    rr:termType rr:IRI.
:pom_009 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_009.
:pm_009 a rr:PredicateMap.
:pom_009 rr:predicateMap :pm_009.
:pm_009 rr:constant cw:inLanguage.
:pom_009 rr:objectMap :om_009.
:om_009 a rr:ObjectMap;
    rr:template "http://localhost:3030/culturalworks/language/{language}";
    rr:termType rr:IRI.
:pom_010 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_010.
:pm_010 a rr:PredicateMap.
:pom_010 rr:predicateMap :pm_010.
:pm_010 rr:constant cw:forRegion.
:pom_011 a rr:PredicateObjectMap.
:map_AlternativeTitleMapping_000 rr:predicateObjectMap :pom_011.
:pm_011 a rr:PredicateMap.
:pom_011 rr:predicateMap :pm_011.
:pm_011 rr:constant cw:hasTitleType.
:rules_000 void:exampleResource :map_TitleAkaTitleTypeMapping_000.
:map_TitleAkaTitleTypeMapping_000 rml:logicalSource :source_006.
:source_006 a rml:LogicalSource;
    rml:source "data/title_aka_title_type.csv";
    rml:referenceFormulation ql:CSV.
:map_TitleAkaTitleTypeMapping_000 a rr:TriplesMap;
    rdfs:label "TitleAkaTitleTypeMapping".
:s_006 a rr:SubjectMap.
:map_TitleAkaTitleTypeMapping_000 rr:subjectMap :s_006.
:s_006 rr:template "http://localhost:3030/culturalworks/aka/{title_id}/{order}".
:pom_012 a rr:PredicateObjectMap.
:map_TitleAkaTitleTypeMapping_000 rr:predicateObjectMap :pom_012.
:pm_012 a rr:PredicateMap.
:pom_012 rr:predicateMap :pm_012.
:pm_012 rr:constant cw:hasTitleType.
:pom_010 rr:objectMap :om_010.
:om_010 a rr:ObjectMap;
    rr:parentTriplesMap :map_RegionIsoLookup_000;
    rr:joinCondition :jc_000.
:jc_000 rr:child "region";
    rr:parent "region".
:pom_010 rr:objectMap :om_011.
:om_011 a rr:ObjectMap;
    rr:parentTriplesMap :map_RegionXcodeLookup_000;
    rr:joinCondition :jc_001.
:jc_001 rr:child "region";
    rr:parent "region".
:pom_011 rr:objectMap :om_012.
:om_012 a rr:ObjectMap;
    rr:parentTriplesMap :map_AdditionalAttrLookup_000;
    rr:joinCondition :jc_002.
:jc_002 rr:child "additional_attrs";
    rr:parent "additional_attrs".
:pom_012 rr:objectMap :om_013.
:om_013 a rr:ObjectMap;
    rr:parentTriplesMap :map_TitleTypeLookup_000;
    rr:joinCondition :jc_003.
:jc_003 rr:child "title_type_id";
    rr:parent "title_type_id".
