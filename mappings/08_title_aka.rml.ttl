:rules_000 a void:Dataset;
    void:exampleResource :map_RegionIsoLookup_000.
:map_RegionIsoLookup_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/generated/region_iso_lookup.csv";
    rml:referenceFormulation ql:CSV.
:map_RegionIsoLookup_000 a rr:TriplesMap;
    rdfs:label "RegionIsoLookup".
:s_000 a rr:SubjectMap.
:map_RegionIsoLookup_000 rr:subjectMap :s_000.
:s_000 rml:reference "region_iri".
:pom_000 a rr:PredicateObjectMap.
:map_RegionIsoLookup_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:constant cw:Region;
    rr:termType rr:IRI.
:rules_000 void:exampleResource :map_RegionXcodeLookup_000.
