@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix cw: <http://localhost:3030/culturalworks/ontology#>.
@prefix film: <http://localhost:3030/culturalworks/film#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:rules_000 a void:Dataset;
    void:exampleResource :map_SeasonMapping_000.
:map_SeasonMapping_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/generated/seasons.csv";
    rml:referenceFormulation ql:CSV.
:map_SeasonMapping_000 a rr:TriplesMap;
    rdfs:label "SeasonMapping".
:s_000 a rr:SubjectMap.
:map_SeasonMapping_000 rr:subjectMap :s_000.
:s_000 rml:reference "season_iri".
:pom_000 a rr:PredicateObjectMap.
:map_SeasonMapping_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:constant cw:WorkVolume;
    rr:termType rr:IRI.
:pom_001 a rr:PredicateObjectMap.
:map_SeasonMapping_000 rr:predicateObjectMap :pom_001.
:pm_001 a rr:PredicateMap.
:pom_001 rr:predicateMap :pm_001.
:pm_001 rr:constant film:seasonNumber.
:pom_001 rr:objectMap :om_001.
:om_001 a rr:ObjectMap;
    rml:reference "season_number";
    rr:termType rr:Literal;
    rr:datatype xsd:integer.
:pom_002 a rr:PredicateObjectMap.
:map_SeasonMapping_000 rr:predicateObjectMap :pom_002.
:pm_002 a rr:PredicateMap.
:pom_002 rr:predicateMap :pm_002.
:pm_002 rr:constant cw:partOfSeries.
:pom_002 rr:objectMap :om_002.
:om_002 a rr:ObjectMap;
    rml:reference "series_iri";
    rr:termType rr:IRI.
:rules_000 void:exampleResource :map_EpisodeVolumeMapping_000.
:map_EpisodeVolumeMapping_000 rml:logicalSource :source_001.
:source_001 a rml:LogicalSource;
    rml:source "data/generated/episode_volume_links.csv";
    rml:referenceFormulation ql:CSV.
:map_EpisodeVolumeMapping_000 a rr:TriplesMap;
    rdfs:label "EpisodeVolumeMapping".
:s_001 a rr:SubjectMap.
:map_EpisodeVolumeMapping_000 rr:subjectMap :s_001.
:s_001 rr:template "http://localhost:3030/culturalworks/title/{title_id}".
:pom_003 a rr:PredicateObjectMap.
:map_EpisodeVolumeMapping_000 rr:predicateObjectMap :pom_003.
:pm_003 a rr:PredicateMap.
:pom_003 rr:predicateMap :pm_003.
:pm_003 rr:constant cw:partOfVolume.
:pom_003 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rml:reference "season_iri";
    rr:termType rr:IRI.
:pom_004 a rr:PredicateObjectMap.
:map_EpisodeVolumeMapping_000 rr:predicateObjectMap :pom_004.
:pm_004 a rr:PredicateMap.
:pom_004 rr:predicateMap :pm_004.
:pm_004 rr:constant film:episodeNumber.
:pom_004 rr:objectMap :om_004.
:om_004 a rr:ObjectMap;
    rml:reference "episode_number";
    rr:termType rr:Literal;
    rr:datatype xsd:integer.
