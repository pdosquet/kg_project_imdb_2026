@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix cw: <https://example.org/culturalworks/ontology#>.
@prefix film: <https://example.org/culturalworks/film#>.
@prefix imdb: <https://example.org/culturalworks/imdb#>.

:rules_000 a void:Dataset;
    void:exampleResource :map_RoleLookup_000.
:map_RoleLookup_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/seeded/role_lookup.csv";
    rml:referenceFormulation ql:CSV.
:map_RoleLookup_000 a rr:TriplesMap;
    rdfs:label "RoleLookup".
:s_000 a rr:SubjectMap.
:map_RoleLookup_000 rr:subjectMap :s_000.
:s_000 rml:reference "role_iri".
:rules_000 void:exampleResource :map_TalentRoleMapping_000.
:map_TalentRoleMapping_000 rml:logicalSource :source_001.
:source_001 a rml:LogicalSource;
    rml:source "data/talent_role.csv";
    rml:referenceFormulation ql:CSV.
:map_TalentRoleMapping_000 a rr:TriplesMap;
    rdfs:label "TalentRoleMapping".
:s_001 a rr:SubjectMap.
:map_TalentRoleMapping_000 rr:subjectMap :s_001.
:s_001 rr:template "https://example.org/culturalworks/person/{talent_id}".
:pom_000 a rr:PredicateObjectMap.
:map_TalentRoleMapping_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant cw:hasProfession.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:parentTriplesMap :map_RoleLookup_000;
    rr:joinCondition :jc_000.
:jc_000 rr:child "role_id";
    rr:parent "role_id".
