@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix cw: <https://example.org/culturalworks/ontology#>.
@prefix film: <https://example.org/culturalworks/film#>.
@prefix imdb: <https://example.org/culturalworks/imdb#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:rules_000 a void:Dataset;
    void:exampleResource :map_CharacterLookup_000.
:map_CharacterLookup_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/generated/characters.csv";
    rml:referenceFormulation ql:CSV.
:map_CharacterLookup_000 a rr:TriplesMap;
    rdfs:label "CharacterLookup".
:s_000 a rr:SubjectMap.
:map_CharacterLookup_000 rr:subjectMap :s_000.
:s_000 rml:reference "character_iri".
:pom_000 a rr:PredicateObjectMap.
:map_CharacterLookup_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:constant cw:FictionalCharacter;
    rr:termType rr:IRI.
:pom_001 a rr:PredicateObjectMap.
:map_CharacterLookup_000 rr:predicateObjectMap :pom_001.
:pm_001 a rr:PredicateMap.
:pom_001 rr:predicateMap :pm_001.
:pm_001 rr:constant cw:name.
:pom_001 rr:objectMap :om_001.
:om_001 a rr:ObjectMap;
    rml:reference "character_name";
    rr:termType rr:Literal.
:rules_000 void:exampleResource :map_FilmContributionMapping_000.
:map_FilmContributionMapping_000 rml:logicalSource :source_001.
:source_001 a rml:LogicalSource;
    rml:source "data/generated/title_principal_resolved.csv";
    rml:referenceFormulation ql:CSV.
:map_FilmContributionMapping_000 a rr:TriplesMap;
    rdfs:label "FilmContributionMapping".
:s_001 a rr:SubjectMap.
:map_FilmContributionMapping_000 rr:subjectMap :s_001.
:s_001 rr:template "https://example.org/culturalworks/contribution/{title_id}/{talent_id}".
:pom_002 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_002.
:pm_002 a rr:PredicateMap.
:pom_002 rr:predicateMap :pm_002.
:pm_002 rr:constant rdf:type.
:pom_002 rr:objectMap :om_002.
:om_002 a rr:ObjectMap;
    rr:constant film:FilmContribution;
    rr:termType rr:IRI.
:pom_003 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_003.
:pm_003 a rr:PredicateMap.
:pom_003 rr:predicateMap :pm_003.
:pm_003 rr:constant cw:contributedBy.
:pom_003 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rr:template "https://example.org/culturalworks/person/{talent_id}";
    rr:termType rr:IRI.
:pom_004 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_004.
:pm_004 a rr:PredicateMap.
:pom_004 rr:predicateMap :pm_004.
:pm_004 rr:constant cw:involves.
:pom_004 rr:objectMap :om_004.
:om_004 a rr:ObjectMap;
    rr:template "https://example.org/culturalworks/title/{title_id}";
    rr:termType rr:IRI.
:pom_005 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_005.
:pm_005 a rr:PredicateMap.
:pom_005 rr:predicateMap :pm_005.
:pm_005 rr:constant imdb:billingOrder.
:pom_005 rr:objectMap :om_005.
:om_005 a rr:ObjectMap;
    rml:reference "order";
    rr:termType rr:Literal;
    rr:datatype xsd:integer.
:pom_006 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_006.
:pm_006 a rr:PredicateMap.
:pom_006 rr:predicateMap :pm_006.
:pm_006 rr:constant cw:hasRole.
:pom_006 rr:objectMap :om_006.
:om_006 a rr:ObjectMap;
    rml:reference "resolved_role_iri";
    rr:termType rr:IRI.
:pom_007 a rr:PredicateObjectMap.
:map_FilmContributionMapping_000 rr:predicateObjectMap :pom_007.
:pm_007 a rr:PredicateMap.
:pom_007 rr:predicateMap :pm_007.
:pm_007 rr:constant film:portrays.
:pom_007 rr:objectMap :om_007.
:om_007 a rr:ObjectMap;
    rr:parentTriplesMap :map_CharacterLookup_000;
    rml:joinCondition :jc_000.
:jc_000 a fnml:FunctionTermMap;
    fnml:functionValue :fn_000.
:fn_000 rr:predicateObjectMap :pomexec_000.
:pomexec_000 rr:predicateMap :pmexec_000.
:pmexec_000 rr:constant fno:executes.
:pomexec_000 rr:objectMap :omexec_000.
:omexec_000 rr:constant "https://w3id.org/imec/idlab/function#equal";
    rr:termType rr:IRI.
:fn_000 rr:predicateObjectMap :pom_008.
:pom_008 a rr:PredicateObjectMap;
    rr:predicateMap :pm_008.
:pm_008 a rr:PredicateMap;
    rr:constant <http://users.ugent.be/~bjdmeest/function/grel.ttl#valueParameter>.
:pom_008 rr:objectMap :om_008.
:om_008 a rr:ObjectMap;
    rr:template "{title_id}_{talent_id}";
    rr:termType rr:Literal.
:fn_000 rr:predicateObjectMap :pom_009.
:pom_009 a rr:PredicateObjectMap;
    rr:predicateMap :pm_009.
:pm_009 a rr:PredicateMap;
    rr:constant <http://users.ugent.be/~bjdmeest/function/grel.ttl#valueParameter2>.
:pom_009 rr:objectMap :om_009.
:om_009 a rr:ObjectMap;
    rml:parentTermMap :ptm_000.
:ptm_000 rr:template "{title_id}_{talent_id}".
