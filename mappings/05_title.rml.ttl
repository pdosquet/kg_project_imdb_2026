@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix cw: <http://localhost:3030/culturalworks/ontology#>.
@prefix film: <http://localhost:3030/culturalworks/film#>.
@prefix imdb: <http://localhost:3030/culturalworks/imdb#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:rules_000 a void:Dataset;
    void:exampleResource :map_ClassLookup_000.
:map_ClassLookup_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "data/generated/title_structure_lookup.csv";
    rml:referenceFormulation ql:CSV.
:map_ClassLookup_000 a rr:TriplesMap;
    rdfs:label "ClassLookup".
:s_000 a rr:SubjectMap.
:map_ClassLookup_000 rr:subjectMap :s_000.
:s_000 rml:reference "class_iri".
:rules_000 void:exampleResource :map_WorkTypeLookup_000.
:map_WorkTypeLookup_000 rml:logicalSource :source_001.
:source_001 a rml:LogicalSource;
    rml:source "data/seeded/content_type_lookup.csv";
    rml:referenceFormulation ql:CSV.
:map_WorkTypeLookup_000 a rr:TriplesMap;
    rdfs:label "WorkTypeLookup".
:s_001 a rr:SubjectMap.
:map_WorkTypeLookup_000 rr:subjectMap :s_001.
:s_001 rml:reference "work_type_iri".
:rules_000 void:exampleResource :map_TitleMapping_000.
:map_TitleMapping_000 rml:logicalSource :source_002.
:source_002 a rml:LogicalSource;
    rml:source "data/title.csv";
    rml:referenceFormulation ql:CSV.
:map_TitleMapping_000 a rr:TriplesMap;
    rdfs:label "TitleMapping".
:s_002 a rr:SubjectMap.
:map_TitleMapping_000 rr:subjectMap :s_002.
:s_002 rr:template "http://localhost:3030/culturalworks/title/{title_id}".
:pom_000 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_001 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_001.
:pm_001 a rr:PredicateMap.
:pom_001 rr:predicateMap :pm_001.
:pm_001 rr:constant cw:primaryTitle.
:pom_001 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rml:reference "primary_title";
    rr:termType rr:Literal.
:pom_002 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_002.
:pm_002 a rr:PredicateMap.
:pom_002 rr:predicateMap :pm_002.
:pm_002 rr:constant cw:originalTitle.
:pom_002 rr:objectMap :om_001.
:om_001 a rr:ObjectMap;
    rml:reference "original_title";
    rr:termType rr:Literal.
:pom_003 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_003.
:pm_003 a rr:PredicateMap.
:pom_003 rr:predicateMap :pm_003.
:pm_003 rr:constant cw:startYear.
:pom_003 rr:objectMap :om_002.
:om_002 a rr:ObjectMap;
    rml:reference "start_year";
    rr:termType rr:Literal;
    rr:datatype xsd:gYear.
:pom_004 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_004.
:pm_004 a rr:PredicateMap.
:pom_004 rr:predicateMap :pm_004.
:pm_004 rr:constant cw:endYear.
:pom_004 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rml:reference "end_year";
    rr:termType rr:Literal;
    rr:datatype xsd:gYear.
:pom_005 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_005.
:pm_005 a rr:PredicateMap.
:pom_005 rr:predicateMap :pm_005.
:pm_005 rr:constant film:runtimeMinutes.
:pom_005 rr:objectMap :om_004.
:om_004 a rr:ObjectMap;
    rml:reference "runtime_minutes";
    rr:termType rr:Literal;
    rr:datatype xsd:integer.
:pom_006 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_006.
:pm_006 a rr:PredicateMap.
:pom_006 rr:predicateMap :pm_006.
:pm_006 rr:constant imdb:isAdult.
:pom_006 rr:objectMap :om_005.
:om_005 a rr:ObjectMap;
    rml:reference "is_adult";
    rr:termType rr:Literal;
    rr:datatype xsd:boolean.
:pom_007 a rr:PredicateObjectMap.
:map_TitleMapping_000 rr:predicateObjectMap :pom_007.
:pm_007 a rr:PredicateMap.
:pom_007 rr:predicateMap :pm_007.
:pm_007 rr:constant cw:hasType.
:pom_000 rr:objectMap :om_006.
:om_006 a rr:ObjectMap;
    rr:parentTriplesMap :map_ClassLookup_000;
    rr:joinCondition :jc_000.
:jc_000 rr:child "title_id";
    rr:parent "title_id".
:pom_007 rr:objectMap :om_007.
:om_007 a rr:ObjectMap;
    rr:parentTriplesMap :map_WorkTypeLookup_000;
    rr:joinCondition :jc_001.
:jc_001 rr:child "content_type_id";
    rr:parent "content_type_id".
